<!DOCTYPE html><html lang="ru"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Салон Gor</title><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#fdf6f0;display:flex;justify-content:center;align-items:center;min-height:100vh;font-family:'Segoe UI',sans-serif}.chat{width:390px;height:700px;background:#fff;border-radius:24px;box-shadow:0 8px 40px rgba(0,0,0,0.13);display:flex;flex-direction:column;overflow:hidden}.header{background:linear-gradient(135deg,#c0748a,#8b3a5a);padding:18px 20px;display:flex;align-items:center;gap:12px}.avatar{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;font-size:22px}.header-name{color:#fff;font-weight:700;font-size:16px}.header-status{color:rgba(255,255,255,0.8);font-size:12px}.dot{width:7px;height:7px;border-radius:50%;background:#7fff7f;display:inline-block}.messages{flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:10px}.msg{display:flex;align-items:flex-end;gap:7px}.msg.user{justify-content:flex-end}.msg-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#c0748a,#8b3a5a);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}.bubble{max-width:72%;padding:10px 14px;font-size:14px;line-height:1.5}.bubble.bot{background:#f5eef1;color:#333;border-radius:18px 18px 18px 4px}.bubble.user{background:linear-gradient(135deg,#c0748a,#8b3a5a);color:#fff;border-radius:18px 18px 4px 18px}.quick{padding:0 14px 10px;display:flex;gap:7px;flex-wrap:wrap}.quick button{background:#fdf0f4;border:1px solid #e0b0c0;border-radius:20px;padding:6px 12px;font-size:12px;color:#8b3a5a;cursor:pointer}.input-area{padding:10px 14px 16px;display:flex;gap:9px;border-top:1px solid #f0e0e8}.input-area input{flex:1;border:1.5px solid #e0b0c0;border-radius:22px;padding:10px 16px;font-size:14px;outline:none;background:#fdf6f0}.send-btn{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#c0748a,#8b3a5a);border:none;cursor:pointer;color:#fff;font-size:16px}.send-btn:disabled{background:#ddd}.typing{display:flex;gap:4px;padding:10px 14px}.typing span{width:7px;height:7px;border-radius:50%;background:#c0748a;animation:bounce 1.2s infinite}.typing span:nth-child(2){animation-delay:0.2s}.typing span:nth-child(3){animation-delay:0.4s}@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}</style></head><body><div class="chat"><div class="header"><div class="avatar">💇</div><div><div class="header-name">Gor</div><div class="header-status"><span class="dot"></span> Онлайн</div></div></div><div class="messages" id="messages"><div class="msg"><div class="msg-avatar">💇</div><div class="bubble bot">Привет! 👋 Добро пожаловать в салон Gor. Чем могу помочь?</div></div></div><div class="quick" id="quick"><button onclick="send('Какие услуги есть?')">Услуги</button><button onclick="send('Хочу записаться')">Записаться</button><button onclick="send('Где вы находитесь?')">Адрес</button><button onclick="send('Режим работы')">Режим работы</button></div><div class="input-area"><input type="text" id="input" placeholder="Написать..." onkeydown="if(event.key==='Enter')send()"><button class="send-btn" id="btn" onclick="send()">➤</button></div></div><script>const S=`Ты администратор салона "Gor". Услуги: 500-1500 сом. Мастера: Айша, Асель, Амина. Адрес: Манас, Ала-Бука, Ак-Там, Жетиген, дом 20. Тел: 0227 17 03 81. Работаем 9:00-19:00. Отвечай кратко по-русски.`;let H=[];async function send(t){const i=document.getElementById('input');const m=t||i.value.trim();if(!m)return;i.value='';document.getElementById('quick').style.display='none';add(m,'user');H.push({role:'user',content:m});const ty=addTyping();document.getElementById('btn').disabled=true;try{const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:S,messages:H})});const d=await r.json();const rep=d.content?.[0]?.text||'Ошибка.';ty.remove();add(rep,'bot');H.push({role:'assistant',content:rep});}catch{ty.remove();add('Ошибка соединения.','bot');}document.getElementById('btn').disabled=false;}function add(t,type){const msgs=document.getElementById('messages');const d=document.createElement('div');d.className='msg '+type;d.innerHTML=type==='bot'?`<div class="msg-avatar">💇</div><div class="bubble bot">${t}</div>`:`<div class="bubble user">${t}</div>`;msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;return d;}function addTyping(){const msgs=document.getElementById('messages');const d=document.createElement('div');d.className='msg';d.innerHTML=`<div class="msg-avatar">💇</div><div class="bubble bot"><div class="typing"><span></span><span></span><span></span></div></div>`;msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;return d;}</script></body></html>
